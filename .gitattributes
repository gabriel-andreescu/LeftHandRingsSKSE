# Auto detect text files and perform LF normalization
* text=auto eol=lf

*.as linguist-language=ActionScript
*.dll  binary
*.lib  binary
*.nif  binary
*.dds  binary
*.bsa  binary
*.xwm  binary
*.wav  binary
*.esp  binary
*.esm  binary
*.pex  binary
Skyrim/Data/Interface/Translations/*.txt text working-tree-encoding=UTF-16LE-BOM eol=CRLF
